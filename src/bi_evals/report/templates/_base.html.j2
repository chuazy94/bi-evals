<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{% block title %}bi-evals report{% endblock %}</title>
<style>
  :root {
    --fg: #1a1a1a;
    --fg-muted: #666;
    --bg: #fafafa;
    --card: #fff;
    --border: #e5e5e5;
    --pass: #2e7d32;
    --fail: #c62828;
    --warn: #ed6c02;
    --bar-bg: #eef0f2;
    --bar-fg: #2e7d32;
    --bar-fg-warn: #ed6c02;
    --bar-fg-fail: #c62828;
    --mono: ui-monospace, "SF Mono", "Roboto Mono", Menlo, Consolas, monospace;
  }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: var(--fg);
    background: var(--bg);
    margin: 0;
    padding: 24px;
    line-height: 1.5;
    font-size: 14px;
  }
  .container { max-width: 1100px; margin: 0 auto; }
  h1 { font-size: 22px; margin: 0 0 4px; }
  h2 { font-size: 16px; margin: 24px 0 12px; letter-spacing: 0.02em; text-transform: uppercase; color: var(--fg-muted); font-weight: 600; }
  h3 { font-size: 14px; margin: 16px 0 8px; }
  .subtitle { color: var(--fg-muted); margin-bottom: 16px; }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 20px;
    margin-bottom: 16px;
  }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--border); vertical-align: middle; }
  th { font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--fg-muted); font-weight: 600; }
  tr:last-child td { border-bottom: none; }
  td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }
  td.mono { font-family: var(--mono); font-size: 12.5px; color: var(--fg-muted); }
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 16px; }
  .stat { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; }
  .stat .label { font-size: 11px; color: var(--fg-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .stat .value { font-size: 20px; font-weight: 600; margin-top: 4px; font-variant-numeric: tabular-nums; }
  .pill { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11.5px; font-weight: 600; }
  .pill.pass { background: #e8f5e9; color: var(--pass); }
  .pill.fail { background: #ffebee; color: var(--fail); }
  .pill.warn { background: #fff4e5; color: var(--warn); }
  .pill.neutral { background: #eef0f2; color: var(--fg-muted); }
  .verdict { padding: 20px 24px; border-radius: 8px; margin-bottom: 24px; display: flex; align-items: center; gap: 16px; }
  .verdict.green { background: #e8f5e9; border: 1px solid var(--pass); color: var(--pass); }
  .verdict.amber { background: #fff4e5; border: 1px solid var(--warn); color: var(--warn); }
  .verdict.red   { background: #ffebee; border: 1px solid var(--fail); color: var(--fail); }
  .verdict .emoji { font-size: 28px; }
  .verdict .text  { font-size: 18px; font-weight: 600; }
  .verdict .sub   { font-size: 13px; font-weight: 400; opacity: 0.85; margin-top: 2px; }
  .bar-row { display: flex; align-items: center; gap: 8px; }
  .bar { flex: 1; height: 8px; background: var(--bar-bg); border-radius: 4px; overflow: hidden; }
  .bar > span { display: block; height: 100%; background: var(--bar-fg); }
  .bar > span.warn { background: var(--bar-fg-warn); }
  .bar > span.fail { background: var(--bar-fg-fail); }
  .bar-value { font-variant-numeric: tabular-nums; font-size: 12px; color: var(--fg-muted); min-width: 48px; text-align: right; }
  .delta.up   { color: var(--pass); }
  .delta.down { color: var(--fail); }
  .delta.flat { color: var(--fg-muted); }
  .muted { color: var(--fg-muted); }
  .footer { margin-top: 32px; color: var(--fg-muted); font-size: 12px; text-align: center; }
  .kbd { font-family: var(--mono); background: var(--bar-bg); padding: 1px 5px; border-radius: 3px; font-size: 12px; }
  details { margin-top: 8px; }
  details summary { cursor: pointer; color: var(--fg-muted); }
  svg.scatter { background: var(--bar-bg); border-radius: 6px; }
  svg.scatter .axis { stroke: var(--fg-muted); stroke-width: 1; }
  svg.scatter .axis-label { fill: var(--fg-muted); font-size: 11px; font-family: -apple-system, sans-serif; }
  svg.scatter .scatter-dot { fill: var(--bar-fg); }
  svg.scatter .scatter-label { fill: var(--fg); font-size: 10px; font-family: var(--mono); }
  ul.prompt-diff { list-style: none; margin: 0; padding: 0; }
  ul.prompt-diff li { padding: 4px 0; display: flex; align-items: center; gap: 8px; }
</style>
</head>
<body>
<div class="container">
{% block content %}{% endblock %}
<div class="footer">Generated by bi-evals. View per-test detail with <span class="kbd">bi-evals view</span>.</div>
</div>
</body>
</html>
