{% extends "_base.html.j2" %}
{% block title %}{{ run.project_name }} — {{ run.run_id }}{% endblock %}
{% block content %}

<h1>{{ run.project_name }}</h1>
<div class="subtitle">
  Run <span class="mono">{{ run.run_id }}</span>
  {% if run.timestamp %} · {{ run.timestamp }}{% endif %}
</div>

{% if available_categories or available_models %}
<form method="get" class="filter-strip">
  {% if available_categories %}
  <label>
    Category:
    <select name="category" onchange="this.form.submit()">
      <option value="">All</option>
      {% for cat in available_categories %}
      <option value="{{ cat }}" {% if active_filters.category == cat %}selected{% endif %}>{{ cat }}</option>
      {% endfor %}
    </select>
  </label>
  {% endif %}
  {% if available_models and available_models|length > 1 %}
  <label>
    Model:
    <select name="model" onchange="this.form.submit()">
      <option value="">All</option>
      {% for m in available_models %}
      <option value="{{ m }}" {% if active_filters.model == m %}selected{% endif %}>{{ m }}</option>
      {% endfor %}
    </select>
  </label>
  {% endif %}
  <noscript><button type="submit">Apply</button></noscript>
  {% if any_filter_active %}
  <a href="?" class="muted">Clear filters</a>
  {% endif %}
</form>
{% endif %}

<div class="summary-grid">
  <div class="stat">
    <div class="label">Tests</div>
    <div class="value">{{ run.test_count }}</div>
  </div>
  <div class="stat">
    <div class="label">Passed</div>
    <div class="value">{{ run.pass_count }}<span class="muted" style="font-size:13px; font-weight:400;"> / {{ run.test_count }}</span></div>
  </div>
  <div class="stat">
    <div class="label">Pass rate</div>
    <div class="value">{{ overall_pass_rate_pct }}%</div>
  </div>
  <div class="stat">
    <div class="label">Cost</div>
    <div class="value">${{ "%.4f"|format(run.total_cost_usd or 0) }}</div>
  </div>
  <div class="stat">
    <div class="label">Latency</div>
    <div class="value">{{ total_latency_s }}s</div>
  </div>
  <div class="stat">
    <div class="label">Tokens</div>
    <div class="value">{{ total_tokens }}</div>
  </div>
</div>

<h2>Scoring rule</h2>
<div class="card">
  <p style="margin: 0;">
    A test passes when (a) every <em>critical dimension</em> is green
    AND (b) the weighted score across all dimensions reaches the pass threshold
    (<strong>{{ "%.2f"|format(pass_threshold) }}</strong>).
    Critical dimensions:
    {% for d in critical_dimensions %}<span class="mono">{{ d }}</span>{% if not loop.last %}, {% endif %}{% endfor %}{% if not critical_dimensions %}<span class="muted">none configured</span>{% endif %}.
  </p>
</div>

{% if failures %}
<h2>Failures{% if failures_total > failures|length %} ({{ failures|length }} of {{ failures_total }} shown){% endif %}</h2>
<div class="card">
  <table>
    <thead>
      <tr>
        <th style="width: 30%;">Test</th>
        <th class="num" style="width: 110px;">Weighted score (&ge; {{ "%.2f"|format(pass_threshold) }})</th>
        <th>Why it failed</th>
      </tr>
    </thead>
    <tbody>
      {% for f in failures %}
      <tr>
        <td>
          <a href="/runs/{{ run.run_id|urlencode }}/tests/{{ f.test_id|urlencode }}{% if f.model %}?model={{ f.model|urlencode }}{% endif %}" class="mono">{{ f.test_id }}</a>
          <div class="muted" style="font-size: 11.5px; margin-top: 2px;">
            {{ f.category }}{% if available_models|length > 1 and f.model %} · <span class="mono">{{ f.model }}</span>{% endif %}
          </div>
        </td>
        <td class="num">{{ "%.2f"|format(f.score) }}</td>
        <td>
          <ul class="failure-reasons">
            {% for d in f.failed_dimensions %}
            <li>
              <span class="pill {% if d.is_critical %}fail{% else %}warn{% endif %}">{{ d.dimension }}</span>
              <span class="reason-text">{{ d.reason or '(no detail captured)' }}</span>
            </li>
            {% endfor %}
          </ul>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if failures_total > failures|length %}
  <p class="muted" style="margin-top: 8px; font-size: 12px;">
    Showing {{ failures|length }} of {{ failures_total }} failures. Click a test for full SQL, trace, and all dimensions.
  </p>
  {% endif %}
</div>
{% endif %}

<h2>Category dashboard</h2>
<div class="card">
  <table>
    <thead>
      <tr>
        <th>Category</th>
        <th class="num">Pass rate</th>
        <th></th>
        <th class="num">Avg score</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for c in categories %}
      <tr>
        <td>{{ c.category }}</td>
        <td class="num">{{ c.pass_count }}/{{ c.test_count }}</td>
        <td style="min-width: 200px;">
          <div class="bar-row">
            <div class="bar"><span class="{{ bar_class(c.pass_rate) }}" style="width: {{ (c.pass_rate * 100)|round(0, 'floor') }}%;"></span></div>
            <div class="bar-value">{{ (c.pass_rate * 100)|round(0, 'floor') }}%</div>
          </div>
        </td>
        <td class="num">{{ "%.2f"|format(c.avg_score) }}</td>
        <td>
          {% if c.pass_rate >= 0.9 %}<span class="pill pass">strong</span>
          {% elif c.pass_rate >= 0.6 %}<span class="pill warn">review</span>
          {% else %}<span class="pill fail">weak</span>{% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<h2>Dimension pass rates</h2>
<div class="card">
  <table>
    <thead>
      <tr>
        <th>Dimension</th>
        <th class="num">Pass rate</th>
        <th></th>
        <th>Tier</th>
      </tr>
    </thead>
    <tbody>
      {% for d in dimensions %}
      <tr>
        <td>{{ d.dimension }}</td>
        <td class="num">{{ d.pass_count }}/{{ d.total }}</td>
        <td style="min-width: 220px;">
          <div class="bar-row">
            <div class="bar"><span class="{{ bar_class(d.pass_rate) }}" style="width: {{ (d.pass_rate * 100)|round(0, 'floor') }}%;"></span></div>
            <div class="bar-value">{{ (d.pass_rate * 100)|round(0, 'floor') }}%</div>
          </div>
        </td>
        <td>{% if d.is_critical %}<span class="pill fail">critical</span>{% else %}<span class="pill neutral">diagnostic</span>{% endif %}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<h2>Cost by model</h2>
<div class="card">
  <table>
    <thead>
      <tr>
        <th>Model</th>
        <th class="num">Tests</th>
        <th class="num">Cost</th>
        <th class="num">Tokens</th>
      </tr>
    </thead>
    <tbody>
      {% for m in models %}
      <tr>
        <td class="mono">{{ m.model }}</td>
        <td class="num">{{ m.test_count }}</td>
        <td class="num">${{ "%.4f"|format(m.total_cost_usd) }}</td>
        <td class="num">{{ m.total_tokens }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if model_summaries %}
<h2>Model comparison</h2>
<div class="card">
  <table>
    <thead>
      <tr>
        <th>Model</th>
        <th class="num">Tests</th>
        <th class="num">Pass rate</th>
        <th class="num">Avg score</th>
        <th class="num">Cost</th>
        <th class="num">Avg latency</th>
      </tr>
    </thead>
    <tbody>
      {% for s in model_summaries %}
      <tr>
        <td class="mono">{{ s.model }}</td>
        <td class="num">{{ s.test_count }}</td>
        <td class="num">{{ (s.pass_rate * 100)|round(0, 'floor') }}%</td>
        <td class="num">{{ "%.2f"|format(s.avg_score) }}</td>
        <td class="num">${{ "%.4f"|format(s.total_cost_usd) }}</td>
        <td class="num">{{ (s.avg_latency_ms / 1000.0)|round(2) }}s</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if scatter_svg %}
  <div style="margin-top: 16px;">{{ scatter_svg|safe }}</div>
  {% endif %}
</div>
{% endif %}

{% if stability %}
<h2>Stability (top 5 flakiest)</h2>
<div class="card">
  <table>
    <thead>
      <tr>
        <th>Test</th>
        <th class="num">Runs</th>
        <th class="num">Flips</th>
        <th class="num">Pass rate</th>
        <th>Current streak</th>
      </tr>
    </thead>
    <tbody>
      {% for s in stability %}
      <tr>
        <td class="mono">{{ s.test_id }}</td>
        <td class="num">{{ s.runs_observed }}</td>
        <td class="num">{{ s.flip_count }}</td>
        <td class="num">{{ (s.pass_rate_overall * 100)|round(0, 'floor') }}%</td>
        <td>
          {% if s.current_streak > 0 %}<span class="pill pass">{{ s.current_streak }} pass</span>
          {% elif s.current_streak < 0 %}<span class="pill fail">{{ -s.current_streak }} fail</span>
          {% else %}<span class="muted">—</span>{% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <p class="muted" style="margin-top: 8px; font-size: 12px;">
    Flip = pass→fail or fail→pass transition across runs. Only tests observed in 2+ runs are shown.
  </p>
</div>
{% endif %}

{% if cost_alert %}
<h2>Cost alert</h2>
<div class="card">
  <p style="margin-top:0;">
    <span class="pill warn">⚠ anomaly</span>
    This run cost <strong>${{ "%.4f"|format(cost_alert.actual_cost) }}</strong>,
    {{ "%.1f"|format(cost_alert.multiplier) }}× the median
    (${{ "%.4f"|format(cost_alert.median_cost) }})
    of the last {{ cost_alert.sample_size }} runs.
  </p>
  {% if cost_alert.anomalous_tests %}
  <table>
    <thead><tr><th>Test</th><th class="num">Actual</th><th class="num">Median</th><th class="num">Multiplier</th></tr></thead>
    <tbody>
      {% for tid, actual, median in cost_alert.anomalous_tests %}
      <tr>
        <td class="mono">{{ tid }}</td>
        <td class="num">${{ "%.4f"|format(actual) }}</td>
        <td class="num">${{ "%.4f"|format(median) }}</td>
        <td class="num">{{ "%.1f"|format(actual / median if median else 0.0) }}×</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</div>
{% endif %}

{% if stale_goldens or unverified_goldens %}
<h2>Dataset freshness</h2>
<div class="card">
  <div class="summary-grid" style="margin-bottom: 12px;">
    <div class="stat">
      <div class="label">Stale goldens</div>
      <div class="value">{{ stale_goldens|length }}</div>
    </div>
    <div class="stat">
      <div class="label">Unverified</div>
      <div class="value">{{ unverified_goldens|length }}</div>
    </div>
    {% if fresh_vs_stale %}
    <div class="stat">
      <div class="label">Fresh pass rate</div>
      <div class="value">{{ (fresh_vs_stale.fresh.pass_rate * 100)|round(0,'floor') }}%</div>
    </div>
    <div class="stat">
      <div class="label">Stale pass rate</div>
      <div class="value">{{ (fresh_vs_stale.stale.pass_rate * 100)|round(0,'floor') }}%</div>
    </div>
    {% endif %}
  </div>
  {% if stale_goldens %}
  <h3>Worst offenders</h3>
  <table>
    <thead><tr><th>Test</th><th class="num">Last verified</th><th class="num">Days ago</th></tr></thead>
    <tbody>
      {% for g in stale_goldens[:10] %}
      <tr>
        <td class="mono">{{ g.test_id }}</td>
        <td class="num">{{ g.last_verified_at }}</td>
        <td class="num">{{ g.days_since_verified }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  <p class="muted" style="margin-top: 8px; font-size: 12px;">
    Stale goldens still execute normally — this is a nudge to re-verify their reference SQL
    against the current database, not a failing condition.
  </p>
</div>
{% endif %}

{% if stale_knowledge %}
<h2>Knowledge freshness</h2>
<div class="card">
  <div class="summary-grid" style="margin-bottom: 12px;">
    <div class="stat">
      <div class="label">Stale files read</div>
      <div class="value">{{ stale_knowledge|length }}</div>
    </div>
    <div class="stat">
      <div class="label">Threshold</div>
      <div class="value">{{ knowledge_stale_after_days }}d</div>
    </div>
  </div>
  <h3>Worst offenders</h3>
  <table>
    <thead><tr><th>File</th><th class="num">Last modified</th><th class="num">Days ago</th></tr></thead>
    <tbody>
      {% for f in stale_knowledge[:10] %}
      <tr>
        <td class="mono">{{ f.path }}</td>
        <td class="num">{{ f.mtime }}</td>
        <td class="num">{{ f.days_since_modified }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <p class="muted" style="margin-top: 8px; font-size: 12px;">
    Only files actually read in this run are checked. Mtime is re-stat'd at report time
    (current disk state). Warning only — no scoring impact.
  </p>
</div>
{% endif %}

{% if tests %}
<h2>All tests{% if any_filter_active %} (filtered){% endif %}</h2>
<div class="card">
  <table>
    <thead>
      <tr>
        <th>Test</th>
        <th>Category</th>
        {% if available_models|length > 1 %}<th>Model</th>{% endif %}
        <th>Status</th>
        <th class="num">Weighted score (&ge; {{ "%.2f"|format(pass_threshold) }})</th>
        <th class="num">Cost</th>
      </tr>
    </thead>
    <tbody>
      {% for t in tests %}
      <tr>
        <td class="mono"><a href="/runs/{{ run.run_id|urlencode }}/tests/{{ t.test_id|urlencode }}{% if t.model %}?model={{ t.model|urlencode }}{% endif %}">{{ t.test_id }}</a></td>
        <td>{{ t.category or '—' }}</td>
        {% if available_models|length > 1 %}<td class="mono">{{ t.model or '—' }}</td>{% endif %}
        <td>{{ pass_pill(t.passed)|safe }}</td>
        <td class="num">{{ "%.2f"|format(t.score) }}</td>
        <td class="num">{% if t.cost_usd is not none %}${{ "%.4f"|format(t.cost_usd) }}{% else %}—{% endif %}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

{% endblock %}
